# ---------------------------------------------------------------------------
# CardMaxxing environment. Copy to .env and fill in real values.
# Generate secrets with:  openssl rand -base64 48
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Local docker-compose default. On Render, use the Internal Database URL.
DATABASE_URL="postgresql://cardmaxxing:cardmaxxing@localhost:5432/cardmaxxing?schema=public"
POSTGRES_USER=cardmaxxing
POSTGRES_PASSWORD=cardmaxxing
POSTGRES_DB=cardmaxxing

# --- Server ---------------------------------------------------------------
NODE_ENV=development
PORT=4000

# --- Auth -----------------------------------------------------------------
# Must be at least 32 characters, and must differ from each other in production.
JWT_ACCESS_SECRET="change_me_to_a_long_random_string_at_least_32_chars"
JWT_REFRESH_SECRET="change_me_to_a_different_long_random_string_32ch"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12

# --- HTTP -----------------------------------------------------------------
# Comma-separated list of allowed browser origins.
CORS_ORIGIN="http://localhost:5173"
# Leave unset unless you are pinning cookies to a specific domain.
# COOKIE_DOMAIN=".yourdomain.com"
# Set to true behind a proxy or load balancer (Render, nginx, Cloudflare).
TRUST_PROXY=false

# --- Rate limiting --------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# --- Optional AI explanation layer ---------------------------------------
# Entirely optional. Without a key the API returns the deterministic reasons only.
# AI never selects or reorders recommendations.
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL=claude-sonnet-5

# --- Frontend (web/.env) --------------------------------------------------
# Absolute API URL for split deployments (Vercel front-end -> Render API).
# Leave unset in development to use the Vite dev proxy.
# VITE_API_URL="https://cardmaxxing-api.onrender.com/api"
